# Local terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and secrets. These should not be part of version 
# control as they are data, not configuration. For templates, check terraform.tfvars.example
# *.tfvars
# *.tfvars.json

# Ignore override files as they are local-only overrides
*.override.tf
*.override.tf.json

# Include override files you do wish to add
# !override.tf

# Include lock file as recommended by HashiCorp
# !.terraform.lock.hcl

# Ignore CLI configuration files
.terraformrc
terraform.rc
